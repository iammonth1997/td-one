generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id          Int        @id @default(autoincrement())
  name        String     @unique @db.VarChar(100)
  description String?
  is_active   Boolean    @default(true)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at  DateTime   @default(now()) @db.Timestamptz(6)
  employees   Employee[]

  @@map("companies")
}

model WorkSite {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("work_sites")
}

model Department {
  id          Int        @id @default(autoincrement())
  name        String     @unique @db.VarChar(100)
  description String?
  is_active   Boolean    @default(true)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at  DateTime   @default(now()) @db.Timestamptz(6)
  employees   Employee[]
  requests    Request[]

  @@map("departments")
}

model Position {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("positions")
}

model WorkingHours {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(50)
  hours     Decimal  @db.Decimal(4, 2)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("working_hours")
}

model EmployeeLevel {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("employee_levels")
}

model JobGroup {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("job_groups")
}

model MineLocation {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("mine_locations")
}

model Employee {
  employee_id         String        @id @db.VarChar(50)
  prefix              String?       @db.VarChar(50)
  first_name          String?       @db.VarChar(100)
  last_name           String?       @db.VarChar(100)
  full_name_en        String?       @db.VarChar(200)
  full_name_lo        String?       @db.VarChar(200)
  date_of_birth       DateTime?     @db.Date
  phone               String?       @db.VarChar(50)
  social_security_no  String?       @db.VarChar(50)
  company_id          Int?
  department_id       Int?
  position            String?       @db.VarChar(200)
  work_location_id    Int?
  cost_center_id      Int?
  mine_site_id        Int?
  level_id            Int?
  payslip_code        String?       @db.VarChar(50)
  shift_type          String?       @db.VarChar(100)
  employee_type       String?       @db.VarChar(100)
  status              String?       @db.VarChar(100)
  group_name          String?       @db.VarChar(100)
  start_date          DateTime?     @db.Date
  last_work_date      DateTime?     @db.Date
  base_salary         Decimal?      @db.Decimal(15, 2)
  skill_allowance     Decimal?      @db.Decimal(15, 2)
  phone_allowance     Decimal?      @db.Decimal(15, 2)
  upcountry_allowance Decimal?      @db.Decimal(15, 2)
  total_salary        Decimal?      @db.Decimal(15, 2)
  bank_account_name   String?       @db.VarChar(200)
  bank_account_no     String?       @db.VarChar(50)
  education_level     String?       @db.VarChar(200)
  field_of_study      String?       @db.VarChar(200)
  institution         String?       @db.VarChar(200)
  experience          String?
  address_full        String?
  address_village     String?       @db.VarChar(200)
  address_district    String?       @db.VarChar(200)
  address_province    String?       @db.VarChar(200)
  eval_30d            DateTime?     @db.Date
  eval_60d            DateTime?     @db.Date
  eval_119d           DateTime?     @db.Date
  license_expiry      String?       @db.VarChar(100)
  blood_group         String?       @db.VarChar(20)
  created_at          DateTime      @default(now()) @db.Timestamptz(6)
  updated_at          DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
  company             Company?      @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_employees_company")
  cost_centers        cost_centers? @relation(fields: [cost_center_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_employees_cost_center")
  department          Department?   @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_employees_department")
  level               levels?       @relation(fields: [level_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_employees_level")
  mine_sites          mine_sites?   @relation(fields: [mine_site_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_employees_mine_site")
  request_assignments RequestEmployee[]
  requests_approved   Request[]     @relation("RequestApprovedBy")
  requests_created    Request[]     @relation("RequestCreatedBy")
  work_locations      WorkLocation? @relation(fields: [work_location_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_employees_work_location")

  @@index([company_id], map: "idx_employees_company_id")
  @@index([cost_center_id], map: "idx_employees_cost_center_id")
  @@index([department_id], map: "idx_employees_department_id")
  @@index([start_date], map: "idx_employees_start_date")
  @@index([status], map: "idx_employees_status")
  @@index([work_location_id], map: "idx_employees_work_location_id")
  @@map("employees")
}

model EmployeeBankAccount {
  id             String   @id @default(uuid()) @db.Uuid
  employee_id    String   @db.Uuid
  account_name   String?
  account_number String?
  bank_name      String?
  is_primary     Boolean  @default(true)
  created_at     DateTime @default(now())

  @@unique([employee_id, account_number])
  @@map("employee_bank_accounts")
}

model EmployeeEducation {
  id              String   @id @default(uuid())
  employee_id     String   @unique @db.Uuid
  education_level String?
  education_field String?
  gpa             Float?
  institution     String?
  created_at      DateTime @default(now())

  @@map("employee_education")
}

model EmployeeExperience {
  id                String   @id @default(uuid())
  employee_id       String   @unique @db.Uuid
  experience_text   String?
  multi_skill       String?
  previous_position String?
  previous_unit     String?
  created_at        DateTime @default(now())

  @@map("employee_experience")
}

model EmployeeAddress {
  id          String  @id @default(uuid())
  employee_id String  @unique @db.Uuid
  address     String?
  village     String?
  district    String?
  province    String?

  @@map("employee_addresses")
}

model LoginUser {
  id                   String    @id @default(uuid()) @db.Uuid
  emp_id               String    @unique
  pin_hash             String?
  role                 String    @default("employee")
  admin                Boolean   @default(false)
  line_user_id         String?
  force_pin_change     Boolean   @default(false)
  must_change_password Boolean   @default(false)
  temp_pin_expires_at  DateTime?
  admin_email          String?   @unique
  admin_password_hash  String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @default(now()) @updatedAt

  @@map("login_users")
}

model AuthSession {
  id            String   @id @default(uuid()) @db.Uuid
  session_token String   @unique
  emp_id        String
  role          String   @default("employee")
  device_id     String?
  expires_at    DateTime
  is_active     Boolean  @default(true)
  login_context String?
  ip_address    String?
  user_agent    String?
  created_at    DateTime @default(now())

  @@map("auth_sessions")
}

model AuthEmployeeDevice {
  id             String    @id @default(uuid()) @db.Uuid
  employee_id    String    @db.Uuid
  device_id      String
  device_name    String?
  platform       String?
  app_version    String?
  registered_at  DateTime  @default(now())
  last_active_at DateTime?
  is_active      Boolean   @default(true)

  @@unique([employee_id, device_id])
  @@map("auth_employee_devices")
}

model AuthLoginAttempt {
  id           String   @id @default(uuid()) @db.Uuid
  emp_id       String
  success      Boolean  @default(false)
  ip_address   String?
  attempted_at DateTime @default(now())

  @@map("auth_login_attempts")
}

model SalarySession {
  id         String   @id @default(uuid()) @db.Uuid
  emp_id     String
  token_hash String   @unique
  expires_at DateTime
  created_at DateTime @default(now())

  @@map("salary_sessions")
}

model PayrollSettings {
  id                       String   @id @default(uuid()) @db.Uuid
  employee_id              String   @unique @db.Uuid
  pay_type                 String
  base_salary              Float?
  daily_rate               Float?
  work_site_id             String?  @db.Uuid
  social_security_enrolled Boolean  @default(true)
  is_active                Boolean  @default(true)
  emp_code                 String?
  created_at               DateTime @default(now())
  updated_at               DateTime @default(now()) @updatedAt

  @@map("payroll_settings")
}

model EmployeePayrollSettings {
  id                       String   @id @default(uuid()) @db.Uuid
  employee_id              String   @unique @db.Uuid
  emp_code                 String?
  pay_type                 String
  base_salary              Float?
  daily_rate               Float?
  bank_account_no          String?
  bank_name                String?
  social_security_no       String?
  social_security_enrolled Boolean  @default(true)
  work_site_id             String?  @db.Uuid
  is_active                Boolean  @default(true)
  updated_at               DateTime @default(now()) @updatedAt

  @@map("employee_payroll_settings")
}

model TaxBracket {
  id             String  @id @default(uuid()) @db.Uuid
  country_code   String
  min_amount     Float
  max_amount     Float?
  rate_percent   Float
  is_active      Boolean @default(true)
  effective_from String
  effective_to   String?

  @@map("tax_brackets")
}

model PayrollRun {
  id                  String    @id @default(uuid()) @db.Uuid
  run_type            String
  period_month        String
  pay_date            String?
  work_site_id        String?   @db.Uuid
  notes               String?
  status              String    @default("draft")
  employee_count      Int?
  total_gross         Float?
  total_deductions    Float?
  total_net           Float?
  total_employer_cost Float?
  approved_by         String?
  approved_at         DateTime?
  paid_at             DateTime?
  created_by          String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  @@map("payroll_runs")
}

model PayrollItem {
  id                       String   @id @default(uuid()) @db.Uuid
  payroll_run_id           String   @db.Uuid
  employee_id              String   @db.Uuid
  emp_code                 String?
  pay_type                 String?
  base_amount              Float?
  work_days                Int?
  work_hours               Float?
  absent_days              Int?
  absent_deduction         Float?
  gross_pay                Float    @default(0)
  social_security_employee Float?
  social_security_employer Float?
  income_tax               Float?
  deductions               Json?
  extra_pay_summary        Json?
  incentive_total          Float?
  total_deductions         Float    @default(0)
  net_pay                  Float    @default(0)
  warnings                 Json?
  status                   String   @default("calculated")
  updated_at               DateTime @default(now()) @updatedAt

  @@unique([payroll_run_id, employee_id])
  @@map("payroll_items")
}

model EmployeeDeduction {
  id                    String             @id @default(uuid()) @db.Uuid
  employee_id           String             @db.Uuid
  custom_name           String?
  amount                Float?
  remaining_amount      Float?
  is_active             Boolean            @default(true)
  start_month           String
  end_month             String?
  notes                 String?
  created_by            String?
  deduction_template_id String?            @db.Uuid
  created_at            DateTime           @default(now())
  deduction_template    DeductionTemplate? @relation(fields: [deduction_template_id], references: [id])

  @@map("employee_deductions")
}

model DeductionTemplate {
  id                  String              @id @default(uuid()) @db.Uuid
  name                String
  name_th             String?
  deduction_type      String
  default_amount      Float?
  default_percentage  Float?
  applies_to_run_type String              @default("salary")
  auto_apply          Boolean             @default(false)
  is_active           Boolean             @default(true)
  deductions          EmployeeDeduction[]

  @@map("deduction_templates")
}

model IncentiveRecord {
  id             String   @id @default(uuid()) @db.Uuid
  employee_id    String   @db.Uuid
  period_month   String
  incentive_type String
  amount         Float    @default(0)
  created_at     DateTime @default(now())

  @@map("incentive_records")
}

model ShiftPattern {
  id                 String            @id @default(uuid()) @db.Uuid
  pattern_name       String
  work_days          Int
  rest_days          Int
  cycle_total_days   Int
  work_hours_per_day Float
  is_active          Boolean           @default(true)
  assignments        ShiftAssignment[]

  @@map("shift_patterns")
}

model ShiftType {
  id               String            @id @default(uuid()) @db.Uuid
  type_name        String
  start_time       String
  end_time         String
  crosses_midnight Boolean           @default(false)
  break_minutes    Int               @default(0)
  is_night_shift   Boolean           @default(false)
  grace_minutes    Int               @default(0)
  is_active        Boolean           @default(true)
  assignments      ShiftAssignment[]

  @@map("shift_types")
}

model ShiftAssignment {
  id               String       @id @default(uuid()) @db.Uuid
  employee_id      String       @db.Uuid
  cycle_start_date String
  effective_from   String
  effective_to     String?
  assigned_by      String?
  shift_pattern_id String       @db.Uuid
  shift_type_id    String       @db.Uuid
  shift_pattern    ShiftPattern @relation(fields: [shift_pattern_id], references: [id])
  shift_type       ShiftType    @relation(fields: [shift_type_id], references: [id])

  @@map("employee_shift_assignments")
}

model Attendance {
  id                   String    @id @default(uuid()) @db.Uuid
  employee_id          String    @db.Uuid
  work_date            String
  status               String    @default("present")
  total_hours          Float?
  scan_in_time         DateTime?
  scan_in_latitude     Float?
  scan_in_longitude    Float?
  scan_in_location_id  String?   @db.Uuid
  scan_in_photo_url    String?
  scan_in_device_id    String?
  scan_out_time        DateTime?
  scan_out_latitude    Float?
  scan_out_longitude   Float?
  scan_out_location_id String?   @db.Uuid
  scan_out_photo_url   String?
  scan_out_device_id   String?
  notes                String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @default(now()) @updatedAt

  @@map("attendance")
}

model MonthlyDayworkSummary {
  id          String @id @default(uuid()) @db.Uuid
  employee_id String @db.Uuid
  month       String
  work_days   Int    @default(0)
  absent_days Int    @default(0)
  total_hours Float  @default(0)

  @@unique([employee_id, month], name: "employee_id_month")
  @@map("monthly_daywork_summary")
}

model AttendanceWorkLocation {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  latitude      Float?
  longitude     Float?
  radius_meters Float?
  boundary_type String?
  boundary_json Json?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  @@map("attendance_work_locations")
}

model AttendanceLog {
  id              String   @id @default(uuid()) @db.Uuid
  employee_id     String?  @db.Uuid
  emp_code        String?
  date            String?
  action_type     String?
  success         Boolean  @default(false)
  reason          String?
  latitude        Float?
  longitude       Float?
  accuracy_meters Float?
  location_id     String?  @db.Uuid
  distance_meters Float?
  device_id       String?
  ip_address      String?
  user_agent      String?
  created_at      DateTime @default(now())

  @@map("attendance_logs")
}

model AttendanceSuspiciousScan {
  id                 String    @id @default(uuid()) @db.Uuid
  employee_id        String?   @db.Uuid
  employee_code      String?
  attendance_id      String?   @db.Uuid
  scan_timestamp     DateTime?
  gps_position       Json?
  suspicion_score    Int       @default(0)
  suspicion_flags    Json?
  face_match_score   Float?
  device_id          String?
  scan_status        String    @default("normal")
  review_action      String    @default("pending")
  review_note        String?
  reviewed_by_emp_id String?
  reviewed_at        DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @default(now()) @updatedAt

  @@map("attendance_suspicious_scans")
}

model SitePayPolicy {
  id             String        @id @default(uuid()) @db.Uuid
  work_site_id   String        @db.Uuid
  effective_from String
  effective_to   String?
  notes          String?
  rates          SitePayRate[]

  @@map("site_pay_policies")
}

model SitePayRate {
  id                 String        @id @default(uuid()) @db.Uuid
  site_pay_policy_id String        @map("policy_id") @db.Uuid
  pay_type           String
  multiplier         Float?
  fixed_amount       Float?
  calculation_method String        @default("multiplier")
  policy             SitePayPolicy @relation(fields: [site_pay_policy_id], references: [id])

  @@unique([site_pay_policy_id, pay_type])
  @@map("site_pay_rates")
}

model PublicHoliday {
  id           String @id @default(uuid()) @db.Uuid
  holiday_date String
  holiday_name String
  country_code String

  @@unique([holiday_date, country_code])
  @@map("public_holidays")
}

model ExtraPayRequest {
  id                String    @id @default(uuid()) @db.Uuid
  employee_id       String    @db.Uuid
  work_date         String
  planned_clock_in  String?
  planned_clock_out String?
  actual_clock_in   String?
  actual_clock_out  String?
  request_type      String
  total_hours       Float?
  reason            String?
  preview_amount    Float?
  status            String    @default("pending_supervisor")
  final_approved_at DateTime?
  rejected_at       DateTime?
  rejected_by       String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @default(now()) @updatedAt

  @@map("extra_pay_requests")
}

model ExtraPayRecord {
  id                   String   @id @default(uuid()) @db.Uuid
  employee_id          String   @db.Uuid
  extra_pay_request_id String?  @db.Uuid
  work_date            String
  pay_type             String
  hours                Float?
  hourly_rate          Float?
  multiplier           Float?
  amount               Float    @default(0)
  source               String?
  period_month         String
  created_at           DateTime @default(now())

  @@map("extra_pay_records")
}

model ApprovalAction {
  id                String   @id @default(uuid()) @db.Uuid
  request_id        String   @db.Uuid
  request_type      String
  approver_emp_code String
  step_order        Int
  action            String
  notes             String?
  created_at        DateTime @default(now())

  @@map("approval_actions")
}

model EmployeeActivation {
  id         String    @id @default(uuid()) @db.Uuid
  emp_id     String
  code       String    @unique
  used_at    DateTime?
  expires_at DateTime?
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())

  @@map("employee_activations")
}

model SecurityAuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  event_type String
  severity   String   @default("info")
  emp_id     String?
  device_id  String?
  ip_address String?
  latitude   Float?
  longitude  Float?
  metadata   Json?
  is_alert   Boolean  @default(false)
  created_at DateTime @default(now())

  @@map("security_audit_logs")
}

model SecurityAlertSent {
  id        String   @id @default(uuid()) @db.Uuid
  rule_name String
  emp_id    String?
  severity  String   @default("info")
  sent_at   DateTime @default(now())

  @@map("security_alerts_sent")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  resource   String?
  actor_id   String?
  metadata   Json?
  created_at DateTime @default(now())

  @@map("audit_logs")
}

model OtType {
  id              String   @id @default(uuid()) @db.Uuid
  code            String   @unique
  name_lo         String?
  name_th         String?
  name_en         String?
  rate_multiplier Float    @default(1.0)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())

  @@map("ot_types")
}

model OtRequest {
  id              String    @id @default(uuid()) @db.Uuid
  employee_id     String    @db.Uuid
  ot_type_code    String
  date            String
  start_time      String
  end_time        String
  total_hours     Float
  rate_multiplier Float
  reason          String
  project_ref     String?
  status          String    @default("pending")
  cross_midnight  Boolean   @default(false)
  approved_by     String?
  approved_at     DateTime?
  rejected_reason String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now()) @updatedAt

  @@map("ot_requests")
}

model LeaveType {
  id                String  @id @default(uuid()) @db.Uuid
  code              String  @unique
  name_lo           String?
  name_th           String?
  name_en           String?
  max_days_per_year Float?
  is_paid           Boolean @default(true)
  is_active         Boolean @default(true)

  @@map("leave_types")
}

model LeaveBalance {
  id              String @id @default(uuid()) @db.Uuid
  employee_id     String @db.Uuid
  leave_type_code String
  year            Int
  total_days      Float  @default(0)
  used_days       Float  @default(0)

  @@unique([employee_id, leave_type_code, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id                        String    @id @default(uuid()) @db.Uuid
  employee_id               String    @db.Uuid
  leave_type_code           String
  start_date                String
  end_date                  String
  total_days                Float
  reason                    String
  attachment_url            String?
  attachment_public_id      String?
  attachment_resource_type  String?
  attachment_active         Boolean   @default(true)
  attachment_inactivated_at DateTime?
  attachment_delete_after   DateTime?
  attachment_deleted_at     DateTime?
  status                    String    @default("pending")
  approved_by               String?
  approved_at               DateTime?
  rejected_reason           String?
  cancelled_at              DateTime?
  created_at                DateTime  @default(now())
  updated_at                DateTime  @default(now()) @updatedAt

  @@map("leave_requests")
}

model Request {
  id               String              @id @default(uuid()) @db.Uuid
  request_type     String              @db.VarChar(50)
  status           String              @default("PENDING") @db.VarChar(20)
  start_date       DateTime?           @db.Date
  end_date         DateTime?           @db.Date
  half_day         String?             @db.VarChar(2)
  total_days       Float?
  work_dates       Json?
  work_hours       Float?
  last_working_day DateTime?           @db.Date
  reason           String?
  is_twins         Boolean             @default(false)
  created_by_id    String              @db.VarChar(50)
  department_id    Int
  approved_by_id   String?             @db.VarChar(50)
  approved_at      DateTime?
  rejection_reason String?
  requires_approval Boolean            @default(true)
  created_at       DateTime            @default(now())
  updated_at       DateTime            @default(now()) @updatedAt
  approved_by      Employee?           @relation("RequestApprovedBy", fields: [approved_by_id], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)
  attachments      RequestAttachment[]
  created_by       Employee            @relation("RequestCreatedBy", fields: [created_by_id], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)
  department       Department          @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employees        RequestEmployee[]

  @@index([approved_by_id], map: "idx_requests_approved_by_id")
  @@index([created_by_id], map: "idx_requests_created_by_id")
  @@index([department_id], map: "idx_requests_department_id")
  @@index([request_type], map: "idx_requests_request_type")
  @@index([status], map: "idx_requests_status")
  @@map("requests")
}

model RequestEmployee {
  id          String  @id @default(uuid()) @db.Uuid
  request_id  String  @db.Uuid
  employee_id String  @db.VarChar(50)
