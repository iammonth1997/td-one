  request     Request @relation(fields: [request_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([employee_id], map: "idx_request_employees_employee_id")
  @@unique([request_id, employee_id], map: "request_employees_request_id_employee_id_key")
