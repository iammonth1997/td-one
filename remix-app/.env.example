# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Auth / security
RESET_PIN_SECRET=your_random_secret_here
CRON_SECRET=your_random_cron_secret

# LINE
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_ADMIN_API_KEY=your_random_admin_key

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_LEAVE_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_LEAVE_SHEET_NAME=LeaveRequests
GOOGLE_APPS_SCRIPT_SYNC_URL=your_apps_script_web_app_url_here

# Attendance
ATTENDANCE_MIN_RADIUS_METERS=100
ATTENDANCE_MAX_RADIUS_METERS=500
ATTENDANCE_DEFAULT_RADIUS_METERS=200

# OT constraints
OT_MAX_HOURS_PER_DAY=4
OT_MAX_PAST_DAYS=7
